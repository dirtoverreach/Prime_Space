# Copy this file to .env and fill in the values.
# Run: cp .env.example .env

# Database
DATABASE_URL=postgresql://primeuser:primepass@postgres:5432/prime_space
POSTGRES_USER=primeuser
POSTGRES_PASSWORD=primepass
POSTGRES_DB=prime_space

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Security — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=REPLACE_ME_WITH_GENERATED_KEY

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Polling
SNMP_POLL_INTERVAL_SECONDS=60
CONFIG_BACKUP_RETENTION_DAYS=90

# Frontend API URL (used by Vite dev server)
VITE_API_URL=http://localhost:8000
